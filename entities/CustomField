{
  "name": "CustomField",
  "type": "object",
  "properties": {
    "field_label": {
      "type": "string",
      "description": "Label shown to the user"
    },
    "field_type": {
      "type": "string",
      "enum": [
        "text",
        "textarea",
        "select",
        "checkbox"
      ],
      "default": "textarea"
    },
    "field_options": {
      "type": "string",
      "description": "Comma-separated options for select fields"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "sort_order": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "field_label"
  ]
}